# Purpose: Prevent generated dependencies, secrets, local runtime data, and agent worktrees from entering git.
# Caller: Git status/add/commit workflows for this CCTV repository.
# Deps: Project build tools, local database/runtime outputs, Codex worktree isolation.
# MainFuncs: Ignore dependency folders, env files, databases, build outputs, backups, exports, and `.worktrees/`.
# SideEffects: Keeps local-only files untracked.

# Dependencies
node_modules/
.npm-cache/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Environment variables
.env
.env.local
.env.production
.env.development
.env.*
*.env

# Database
backend/data/*.db
backend/data/*.db-journal
backend/data/*.db-shm
backend/data/*.db-wal
*.sql
*.sqlite
*.sqlite3

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
frontend/dist/
frontend/build/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Kiro IDE
.kiro/
.agent/

# OS
.DS_Store
Thumbs.db

# MediaMTX
mediamtx/recordings/
mediamtx/logs/

# Temporary files
tmp/
temp/
*.tmp
.worktrees/
private_exports/
private_imports/

# Local CCTV import/export and debug artifacts
/tmp_*
/*.dec.txt
/*.sec
/*.apk
/*_import_*.json
/*_raw_*.json
/*_catalog_*.json
/cctv_backup_*.json
/private_exports/

# Backup files (SECURITY)
*.bak
*.backup
*.old
*.orig
*.save

# Config backups (SECURITY)
config.php.bak
config.js.bak
config.json.bak
*.config.bak

# Git directory (SECURITY)
.git/

# Apache configs (SECURITY)
.htaccess
.htpasswd

# SSH keys (SECURITY)
*.pem
*.key
id_rsa
id_rsa.pub

# Certificates (SECURITY)
*.crt
*.cer
*.p12
*.pfx

# Generated client configuration (per-installation)
deployment/client.config.sh
